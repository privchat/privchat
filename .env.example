# PrivChat Server 环境变量模板（P2-07）
#
# 用法：cp .env.example .env，填入真实值。.env 已被 .gitignore，切勿提交。
# 生产密钥务必用高强度随机值，且不同环境（dev/staging/prod）用不同密钥。
#
# 以下 4 项为必填，未配置时服务器将拒绝启动。

# 数据库连接字符串，如 postgres://user:pass@host:5432/privchat
DATABASE_URL=

# JWT 密钥（HS256 模式用；RS256 模式改用 .local/keys 下的 PEM，见 keys/README.md）。
# ⚠️ 泄露即可伪造任意用户 token —— 生产必须高强度随机，且严禁进 repo。
PRIVCHAT_JWT_SECRET=

# Service Master Key（admin / service-to-service API 认证）。
# ⚠️ 泄露即拥有 admin 全权 —— 生产必须高强度随机，且严禁进 repo。
SERVICE_MASTER_KEY=

# Redis / KeyDB 连接地址，如 redis://127.0.0.1:6379
REDIS_URL=

# Push 配置（按需启用；enabled=false 时其余字段可留空）
PUSH_ENABLED=false

# APNs
PUSH_APNS_ENABLED=false
PUSH_APNS_BUNDLE_ID=
PUSH_APNS_TEAM_ID=
PUSH_APNS_KEY_ID=
PUSH_APNS_PRIVATE_KEY_PATH=
PUSH_APNS_USE_SANDBOX=true

# FCM
PUSH_FCM_ENABLED=false
PUSH_FCM_PROJECT_ID=
PUSH_FCM_ACCESS_TOKEN=

# HMS (Huawei / HarmonyOS / Honor)
PUSH_HMS_ENABLED=false
PUSH_HMS_APP_ID=
PUSH_HMS_ACCESS_TOKEN=
PUSH_HMS_ENDPOINT=

# Honor (HMS protocol, separate keys)
PUSH_HONOR_ENABLED=false
PUSH_HONOR_APP_ID=
PUSH_HONOR_ACCESS_TOKEN=
PUSH_HONOR_ENDPOINT=

# Xiaomi
PUSH_XIAOMI_ENABLED=false
PUSH_XIAOMI_APP_ID=
PUSH_XIAOMI_ACCESS_TOKEN=
PUSH_XIAOMI_ENDPOINT=

# OPPO
PUSH_OPPO_ENABLED=false
PUSH_OPPO_APP_ID=
PUSH_OPPO_ACCESS_TOKEN=
PUSH_OPPO_ENDPOINT=

# Vivo
PUSH_VIVO_ENABLED=false
PUSH_VIVO_APP_ID=
PUSH_VIVO_ACCESS_TOKEN=
PUSH_VIVO_ENDPOINT=

# Lenovo
PUSH_LENOVO_ENABLED=false
PUSH_LENOVO_APP_ID=
PUSH_LENOVO_ACCESS_TOKEN=
PUSH_LENOVO_ENDPOINT=

# ZTE
PUSH_ZTE_ENABLED=false
PUSH_ZTE_APP_ID=
PUSH_ZTE_ACCESS_TOKEN=
PUSH_ZTE_ENDPOINT=

# Meizu
PUSH_MEIZU_ENABLED=false
PUSH_MEIZU_APP_ID=
PUSH_MEIZU_ACCESS_TOKEN=
PUSH_MEIZU_ENDPOINT=
